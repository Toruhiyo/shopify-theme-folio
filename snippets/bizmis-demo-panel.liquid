{%- comment -%}
  Floating Bizmis coachmark (BIZ-134).

  A compact speech bubble that pops above the Bizmis voice widget, rotating one
  use case at a time (each tagged with its benefit / sub-benefit). It tracks the
  widget element so it stays anchored even while the widget is dragged. The
  early-access code rides in from bizmis.ai/demo (?code=) and is applied by
  bizmis-demo.js via the shared data-bizmis-* hooks.
{%- endcomment -%}

{%- if settings.bizmis_demo_enabled -%}
  {%- liquid
    assign listing_url = settings.bizmis_app_listing_url | default: settings.bizmis_app_listing_url_fallback
    assign prompts = 'bizmis.panel.examples' | t | newline_to_br | split: '<br />'
    assign tags = 'bizmis.panel.example_tags' | t | newline_to_br | split: '<br />'
  -%}
  <aside class="bizmis-coach" data-bizmis-coach aria-label="{{ 'bizmis.panel.title' | t | escape }}" aria-live="polite" hidden>
    <div class="bizmis-coach__bubble" data-bizmis-coach-bubble>
      <span
        class="bizmis-coach__watermark"
        style="-webkit-mask-image: url('{{ 'bizmis-logo-white-transparent.png' | asset_url }}'); mask-image: url('{{ 'bizmis-logo-white-transparent.png' | asset_url }}');"
        aria-hidden="true"
      ></span>

      <div class="bizmis-coach__slides" data-bizmis-coach-slides>
        {%- for prompt in prompts -%}
          {%- assign trimmed = prompt | strip -%}
          {%- if trimmed != blank -%}
            {%- assign tag = tags[forloop.index0] | strip -%}
            <figure class="bizmis-coach__slide" data-bizmis-coach-slide>
              {%- if tag != blank -%}
                <figcaption class="bizmis-coach__tag label-caps">{{ tag }}</figcaption>
              {%- endif -%}
              <blockquote class="bizmis-coach__prompt">{% assign words = trimmed | split: ' ' %}{% for word in words %}<span class="bizmis-coach__word" style="--i: {{ forloop.index0 }}">{{ word }}</span>{% unless forloop.last %} {% endunless %}{% endfor %}</blockquote>
            </figure>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <a
        href="{{ listing_url | escape }}"
        class="btn btn--small bizmis-coach__cta"
        data-bizmis-install
        data-label-with-code="{{ 'bizmis.panel.install_with_code' | t | escape }}"
        data-label-no-code="{{ 'bizmis.panel.install' | t | escape }}"
        target="_blank"
        rel="noopener"
      >
        <svg class="bizmis-coach__cta-icon" viewBox="0 0 448 512" aria-hidden="true" focusable="false"><path fill="currentColor" d="M388.32,104.1a4.66,4.66,0,0,0-4.4-4c-2,0-37.23-.8-37.23-.8s-21.61-20.82-29.62-28.83V503.2L442.76,472S388.72,106.5,388.32,104.1ZM288.65,70.47a116.67,116.67,0,0,0-7.21-17.61C271,32.85,255.42,22,237,22a15,15,0,0,0-4,.4c-.4-.8-1.2-1.2-1.6-2C223.4,11.63,213,7.63,200.58,8c-24,.8-48,18-67.25,48.83-13.61,21.62-24,48.84-26.82,70.06-27.62,8.4-46.83,14.41-47.23,14.81-14,4.4-14.41,4.8-16,18-1.2,10-38,291.82-38,291.82L307.86,504V65.67a41.66,41.66,0,0,0-4.4.4S297.86,67.67,288.65,70.47ZM233.41,87.69c-16,4.8-33.63,10.4-50.84,15.61,4.8-18.82,14.41-37.63,25.62-50,4.4-4.4,10.41-9.61,17.21-12.81C232.21,54.86,233.81,74.48,233.41,87.69ZM200.58,24.44A27.49,27.49,0,0,1,215,28c-6.4,3.2-12.81,8.41-18.81,14.41-15.21,16.42-26.82,42-31.62,66.45-14.42,4.41-28.83,8.81-42,12.81C131.33,83.28,163.75,25.24,200.58,24.44ZM154.15,244.61c1.6,25.61,69.25,31.22,73.25,91.66,2.8,47.64-25.22,80.06-65.65,82.47-48.83,3.2-75.65-25.62-75.65-25.62l10.4-44s26.82,20.42,48.44,18.82c14-.8,19.22-12.41,18.81-20.42-2-33.62-57.24-31.62-60.84-86.86-3.2-46.44,27.22-93.27,94.47-97.68,26-1.6,39.23,4.81,39.23,4.81L221.4,225.39s-17.21-8-37.63-6.4C154.15,221,153.75,239.8,154.15,244.61ZM249.42,82.88c0-12-1.6-29.22-7.21-43.63,18.42,3.6,27.22,24,31.23,36.43Q262.63,78.68,249.42,82.88Z"/></svg>
        <span data-bizmis-install-label>{{ 'bizmis.panel.install' | t }}</span>
      </a>
    </div>
  </aside>
{%- endif -%}
