  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "default": 1200,
        "unit": "px",
        "label": "Page width"
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 16,
        "step": 2,
        "default": 8,
        "unit": "px",
        "label": "Border radius"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/shopname"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook",
