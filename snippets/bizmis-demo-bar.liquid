{%- comment -%}
  Bizmis early-access demo bar (BIZ-134).

  Sticky top bar shown on the demo storefront. It carries the lead's early-access
  code (read from the ?code= query param that bizmis.ai/demo forwards in) over to
  the Shopify App Store install, so the code is redeemed at install instead of
  being printed in the cold email. Hydration + persistence live in bizmis-demo.js.
{%- endcomment -%}

{%- if settings.bizmis_demo_enabled -%}
  {%- liquid
    assign listing_url = settings.bizmis_app_listing_url | default: settings.bizmis_app_listing_url_fallback
    assign fallback_code = settings.bizmis_demo_fallback_code
  -%}
  <aside
    class="bizmis-demo-bar"
    data-bizmis-demo-bar
    data-listing-url="{{ listing_url | escape }}"
    data-fallback-code="{{ fallback_code | escape }}"
    aria-label="Bizmis early access"
    hidden
  >
    <div class="page-width bizmis-demo-bar__inner">
      <p class="bizmis-demo-bar__message">
        <span class="bizmis-demo-bar__dot" aria-hidden="true"></span>
        <span class="bizmis-demo-bar__lead">This is the live Bizmis demo store.</span>
        <span class="bizmis-demo-bar__sub">Browse freely, then bring the voice clerk to your own shop.</span>
      </p>

      <div class="bizmis-demo-bar__actions">
        <span class="bizmis-demo-bar__code" data-bizmis-code-chip hidden>
          <span class="bizmis-demo-bar__code-label">Code</span>
          <code data-bizmis-code></code>
          <button
            type="button"
            class="bizmis-demo-bar__copy"
            data-bizmis-code-copy
            data-copied-label="Copied"
            aria-label="Copy early-access code"
          >Copy</button>
        </span>

        <a
          href="{{ listing_url | escape }}"
          class="btn btn--small bizmis-demo-bar__cta"
          data-bizmis-install
          data-label-with-code="Install with your code"
          data-label-no-code="Install Bizmis"
          target="_blank"
          rel="noopener"
        >Install Bizmis</a>

        <button
          type="button"
          class="bizmis-demo-bar__dismiss"
          data-bizmis-demo-dismiss
          aria-label="Dismiss"
        >{% render 'icon-close' %}</button>
      </div>
    </div>
  </aside>
{%- endif -%}
