<section class="section-spacing">
  <div class="page-width">
    <div class="section-header">
      {%- if section.settings.label != blank -%}
        <span class="section-header__label label-caps text-muted">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="section-header__title h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- if section.settings.show_filters -%}
      <div class="filter-tabs" data-filter-tabs>
        <button class="filter-tab is-active" data-filter="all">All</button>
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter_tab' and block.settings.label != blank -%}
            <button class="filter-tab" data-filter="{{ block.settings.tag | handleize }}">
              {{ block.settings.label }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="grid grid--{{ section.settings.columns }}">
      {% render 'product-grid-items', section: section %}
    </div>

    {%- if section.settings.show_view_all -%}
      {%- liquid
        assign view_all_tag = section.settings.product_tag | default: 'new' | handleize
        assign view_all_url = routes.all_products_collection_url | append: '/' | append: view_all_tag
      -%}
      <div class="text-center mt-xl">
        <a href="{{ view_all_url }}" class="btn btn--secondary">
          {{ 'sections.product_grid.view_all' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "tag": "section",
  "class": "product-grid-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows products tagged in Shopify admin. Open a product → Tags → add the tag below (default: new)."
    },
    {
      "type": "text",
      "id": "label",
      "default": "New Arrivals",
      "label": "Label"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Just In",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "product_tag",
      "label": "New product tag",
      "default": "new",
      "info": "Case-insensitive. Add this tag under Products → [product] → Tags in Shopify admin."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Columns"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View all' button"
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "default": false,
      "label": "Show filter tabs"
    }
  ],
  "blocks": [
    {
      "type": "filter_tab",
      "name": "Filter tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Product tag to filter by"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product grid",
      "settings": {
        "product_tag": "new"
      }
    }
  ]
}
{% endschema %}
