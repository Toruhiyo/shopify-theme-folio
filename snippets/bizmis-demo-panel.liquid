{%- comment -%}
  Floating Bizmis coachmark (BIZ-134).

  A minimal, page-wide hint that rotates through one use case at a time, each
  tagged with its benefit / sub-benefit. The early-access code rides in from
  bizmis.ai/demo (?code=) and is applied by bizmis-demo.js via the shared
  data-bizmis-* hooks. Rendered once at layout level so it persists across the
  whole store, not just the hero.
{%- endcomment -%}

{%- if settings.bizmis_demo_enabled -%}
  {%- liquid
    assign listing_url = settings.bizmis_app_listing_url | default: settings.bizmis_app_listing_url_fallback
    assign prompts = 'bizmis.panel.examples' | t | newline_to_br | split: '<br />'
    assign tags = 'bizmis.panel.example_tags' | t | newline_to_br | split: '<br />'
  -%}
  <aside class="bizmis-coach" data-bizmis-coach aria-label="{{ 'bizmis.panel.title' | t | escape }}" aria-live="polite" hidden>
    <button type="button" class="bizmis-coach__close" data-bizmis-coach-close aria-label="{{ 'accessibility.close' | t | escape }}">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M2 2l8 8M10 2l-8 8"/></svg>
    </button>

    <img
      class="bizmis-coach__logo"
      src="{{ 'bizmis-logo-white-transparent.png' | asset_url }}"
      alt="Bizmis"
      width="281"
      height="281"
      loading="lazy"
    >

    <div class="bizmis-coach__slides" data-bizmis-coach-slides>
      {%- for prompt in prompts -%}
        {%- assign trimmed = prompt | strip -%}
        {%- if trimmed != blank -%}
          {%- assign tag = tags[forloop.index0] | strip -%}
          <figure class="bizmis-coach__slide{% if forloop.first %} is-active{% endif %}" data-bizmis-coach-slide>
            {%- if tag != blank -%}
              <figcaption class="bizmis-coach__tag label-caps">{{ tag }}</figcaption>
            {%- endif -%}
            <blockquote class="bizmis-coach__prompt">{{ trimmed }}</blockquote>
          </figure>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="bizmis-coach__foot">
      <a
        href="{{ listing_url | escape }}"
        class="bizmis-coach__cta"
        data-bizmis-install
        data-label-with-code="{{ 'bizmis.panel.install_with_code' | t | escape }}"
        data-label-no-code="{{ 'bizmis.panel.install' | t | escape }}"
        target="_blank"
        rel="noopener"
      >{{ 'bizmis.panel.install' | t }}</a>

      <span class="bizmis-coach__code" data-bizmis-code-chip hidden>
        <code data-bizmis-code></code>
        <button
          type="button"
          class="bizmis-coach__copy"
          data-bizmis-code-copy
          data-copied-label="{{ 'bizmis.panel.copied' | t | escape }}"
          aria-label="{{ 'bizmis.panel.copy_aria' | t | escape }}"
        >{{ 'bizmis.panel.copy' | t }}</button>
      </span>
    </div>
  </aside>
{%- endif -%}
