{%- liquid
  assign all_products = collections.all.products
  assign row_count = 4
  assign max_per_row = 20
-%}

<section class="hero-mosaic" data-mosaic-speed="{{ section.settings.scroll_speed }}">
  {%- if all_products.size > 0 -%}
    <div class="hero-mosaic__bg" aria-hidden="true">
      {%- for row in (1..row_count) -%}
        {%- assign direction = row | modulo: 2 -%}
        <div class="hero-mosaic__row" data-mosaic-row data-direction="{{ direction }}" data-row-index="{{ forloop.index0 }}">
          <div class="hero-mosaic__track">
            {%- for i in (1..2) -%}
              {%- for product in all_products limit: max_per_row -%}
                <a href="{{ product.url }}" class="hero-mosaic__card" tabindex="-1">
                  {%- if product.featured_media -%}
                    <img
                      src="{{ product.featured_media | image_url: width: 300 }}"
                      alt="{{ product.featured_media.alt | escape | default: product.title | escape }}"
                      loading="eager"
                      width="150"
                      height="225"
                    >
                  {%- else -%}
                    <div class="hero-mosaic__card-placeholder">
                      <span>{{ product.title | truncate: 20 }}</span>
                    </div>
                  {%- endif -%}
                </a>
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="hero-mosaic__overlay"></div>

  <div class="hero-mosaic__content">
    {%- if section.settings.label != blank -%}
      <span class="hero-mosaic__label label-caps">{{ section.settings.label }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-mosaic__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-mosaic__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-mosaic-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "default": "Welcome to our bookshop",
      "label": "Label"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Stories Worth Discovering",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "default": "Curated collections of books, stationery, and literary gifts for every kind of reader.",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 50,
      "unit": "s",
      "label": "Scroll speed (duration per cycle)"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
